PORT=4000
NODE_ENV=development
JWT_SECRET=secret_12345
FRONTEND_URL=http://localhost:5173
SESSION_SECRET=recruitech_session_secret
MONGODB_URL=mongodb://localhost:27017/recruitech

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback

# Kafka — when backend runs on the host, use localhost:9092 (Kafka maps 9092 in kafka/docker-compose.yaml).
# Use kafka:9094 only for processes inside Docker on the recruitech-kafka network.
## Todo: Discuss with Shantanu
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_EVALUATION_COMPLETE_TOPIC=evaluation-complete

# Interview-service gRPC (required for sendAiInterview — creation is delegated to interview-service)
INTERVIEW_SERVICE_GRPC_ADDRESS=localhost:50051
# GRPC_INTERNAL_SECRET=

# Presigned recording link lifetime (seconds). Max 604800 (7 days — S3 SigV4 limit). Default 7 days if unset.
# S3_RECORDING_PRESIGN_EXPIRES_SECONDS=604800

# Interview HTTP base — only needed for recruiter playback of LOCAL recording paths (/api/interviews/recordings/...)
# INTERVIEW_SERVICE_HTTP_URL=http://localhost:5001
